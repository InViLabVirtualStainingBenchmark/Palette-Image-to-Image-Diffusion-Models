{
    "name": "mist_pr",
    "gpu_ids": [0],
    "seed" : 42,
    "finetune_norm": false,

    "path": {
        "base_dir": "experiments",
        "code": "code",
        "tb_logger": "tb_logger",
        "results": "results",
        "checkpoint": "checkpoint",
        "resume_state": null
    },

    "datasets": {
        "train": { 
            "which_dataset": {
                "name": ["data.dataset", "ColorizationDataset"],
                "args":{
                    "data_root": "data/mist_pr",
                    "data_flist": "data/mist_pr/flist/train.flist",
                    "image_size": [256, 256],
                    "data_len": -1
                } 
            },
            "dataloader":{
                "validation_split": 2,
                "args":{
                    "batch_size": 1,
                    "num_workers": 1,
                    "shuffle": true,
                    "pin_memory": true,
                    "drop_last": true
                },
                "val_args":{
                    "batch_size": 1,
                    "num_workers": 1,
                    "shuffle": false,
                    "pin_memory": true,
                    "drop_last": false
                }
            }
        },
        "test": { 
            "which_dataset": {
                "name": "ColorizationDataset",
                "args":{
                    "data_root": "data/mist_pr",
                    "data_flist": "data/mist_pr/flist/train.flist",
                    "image_size": [256, 256]
                }
            },
            "dataloader":{
                "args":{
                    "batch_size": 1,
                    "num_workers": 1,
                    "pin_memory": true
                }
            }
        }
    },

    "model": {
        "which_model": {
            "name": ["models.model", "Palette"],
            "args": {
                "sample_num": 1,
                "task": "colorization",
                "ema_scheduler": {
                    "ema_start": 1,
                    "ema_iter": 1,
                    "ema_decay": 0.9999
                },
                "optimizers": [
                    { "lr": 5e-5, "weight_decay": 0}
                ]
            }
        }, 
        "which_networks": [
            {
                "name": ["models.network", "Network"],
                "args": {
                    "init_type": "kaiming",
                    "module_name": "guided_diffusion",
                    "unet": {
                        "in_channel": 6,
                        "out_channel": 3,
                        "inner_channel": 32,
                        "channel_mults": [
                            1,
                            2,
                            4,
                            8
                        ],
                        "attn_res": [
                            16
                        ],
                        "num_head_channels": 32,
                        "res_blocks": 2,
                        "dropout": 0.2,
                        "image_size": 256
                    },
                    "beta_schedule": {
                        "train": {
                            "schedule": "linear",
                            "n_timestep": 2000,
                            "linear_start": 1e-6,
                            "linear_end": 0.01
                        },
                        "test": {
                            "schedule": "linear",
                            "n_timestep": 10,
                            "linear_start": 1e-4,
                            "linear_end": 0.09
                        }
                    }
                }
            }
        ],
        "which_losses": [
            "mse_loss"
        ],
        "which_metrics": [
            "mae"
        ]
    },

    "train": {
        "n_epoch": 1,
        "n_iter": 10,
        "val_epoch": 1,
        "save_checkpoint_epoch": 1,
        "log_iter": 1,
        "tensorboard" : true
    },
    
    "debug": {
        "val_epoch": 1,
        "save_checkpoint_epoch": 1,
        "log_iter": 1,
        "debug_split": 10
    }
}
